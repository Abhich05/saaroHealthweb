# Example environment variables for Saaro Health frontend
# Copy to .env and fill with project-specific values. Do NOT commit real secrets.

# Backend API URL
VITE_API_BASE_URL=

# Python VoiceRx Service URL
VITE_VOICE_SERVICE_URL=

# Google Maps API Key (keep secret; rotate if exposed)
VITE_GOOGLE_MAPS_API_KEY=

# Static outbound IPs for backend allowlisting (optional)
VITE_STATIC_IP_1=
VITE_STATIC_IP_2=
VITE_STATIC_IP_3=
VITE_STATIC_IP_4=
VITE_STATIC_IP_5=
VITE_STATIC_IP_6=

# Frontend Configuration
VITE_APP_NAME=Saaro Health
VITE_APP_VERSION=1.0.0

# Development Configuration
# Vite sets mode automatically via command; prefer using import.meta.env.MODE
VITE_DEV_MODE=development
