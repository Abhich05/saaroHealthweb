# Production Environment Variables

# Backend API (Node/Express)
VITE_API_BASE_URL=https://saarohealthweb-1.onrender.com/api

# Python VoiceRx Service
# IMPORTANT: Set this to the Render URL of the VoiceRx FastAPI service (base, no trailing slash)
# Example: https://saarohealth-voice.onrender.com
VITE_VOICE_SERVICE_URL=

# App metadata
VITE_APP_NAME=Saaro Health
VITE_APP_VERSION=1.0.0
